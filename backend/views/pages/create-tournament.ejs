<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Create Tournament</title>

  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">

  <style>
  body {
  margin: 0;
  font-family: 'Barlow', sans-serif;
  color: white;
  padding-top: 80px;

  background: 
    linear-gradient(rgba(6,8,16,0.45), rgba(6,8,16,0.55)),
    url('/assets/bg-court.png') center/cover no-repeat;

  background-attachment: fixed;
}

    /* BACKGROUND IMAGE */
    .bg-image {
      position: fixed;
      inset: 0;
      filter: brightness(0.35);
      z-index: -2;
    }

    /* DARK OVERLAY */
    .overlay {
      position: fixed;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,122,24,0.1), transparent 70%);
      z-index: -1;
    }

    /* FORM CONTAINER */
    .form-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 80vh;
    }

    .form-card {
      width: 100%;
      max-width: 550px;
      padding: 35px;

      border-radius: 18px;
      background: rgba(10, 12, 24, 0.85);
      backdrop-filter: blur(14px);

      border: 1px solid rgba(255,122,24,0.15);
      box-shadow: 0 20px 60px rgba(0,0,0,0.7);
    }

    .form-card h2 {
      font-family: 'Anton', sans-serif;
      letter-spacing: 2px;
      margin-bottom: 25px;
      font-size: 32px;
    }

    /* INPUTS */
    .form-card input {
      width: 100%;
      margin-bottom: 14px;
      padding: 14px;

      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.08);

      background: rgba(255,255,255,0.04);
      color: white;

      font-family: 'Barlow', sans-serif;
    }

    .form-card input:focus {
      outline: none;
      border-color: #ff7a18;
      box-shadow: 0 0 10px rgba(255,122,24,0.3);
    }

    /* FILE INPUT */
    .form-card input[type="file"] {
      background: transparent;
      border: none;
      color: #aaa;
    }

    /* BUTTON */
    .form-card button {
      width: 100%;
      padding: 14px;

      border-radius: 10px;
      border: none;

      background: linear-gradient(90deg, #ff7a18, #ff8f32);
      color: white;

      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;

      cursor: pointer;
      transition: 0.25s;
    }

    .form-card button:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(255,122,24,0.4);
    }

  </style>
</head>
<body>

<%- include("../partials/navbar") %>

<!-- BACKGROUND -->
<div class="bg-image"></div>
<div class="overlay"></div>

<div class="form-wrapper">
  <div class="form-card">
    <h2>Create Tournament</h2>

    <form action="/tournaments/create" method="POST" enctype="multipart/form-data">

      <input type="text" name="name" placeholder="Tournament Name" required>
      <input type="text" name="location" placeholder="Location" required>

      <input type="date" name="start_date" required>
      <input type="date" name="end_date" required>

      <input type="number" name="max_teams" placeholder="Max Teams" required>

      <input type="file" name="image" accept="image/*">

      <button type="submit">Create Tournament</button>

    </form>
  </div>
</div>

</body>
</html>