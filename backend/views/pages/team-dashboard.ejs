<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>Dashboard - CourtCommand</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    /* TOURNAMENT SECTION */
    .tournament-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .tournament-card {
      position: relative;
      padding: 18px;
      border-radius: 16px;
      background: linear-gradient(145deg, #0c1020, #0a0d18);
      border: 1px solid rgba(255, 255, 255, 0.05);
      transition: 0.3s ease;
      overflow: hidden;
    }

    .tournament-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top left, rgba(255, 122, 24, 0.15), transparent);
      opacity: 0;
      transition: 0.3s;
    }

    .tournament-card:hover::before {
      opacity: 1;
    }

    .tournament-card:hover {
      transform: translateY(-6px) scale(1.02);
      border-color: rgba(255, 122, 24, 0.3);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
    }

    .tournament-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .tournament-header h4 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 20px;
      letter-spacing: 1px;
      color: white;
    }

    .t-badge {
      font-size: 10px;
      padding: 4px 8px;
      border-radius: 6px;
      background: rgba(255, 122, 24, 0.15);
      color: #ff7a18;
      font-weight: 700;
      letter-spacing: 1px;
    }

    .t-location {
      margin-top: 10px;
      font-size: 13px;
      color: #6c728a;
    }

    .t-footer {
      margin-top: 18px;
    }

    .join-btn {
      width: 100%;
      padding: 10px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(135deg, #ff7a18, #ff9a3c);
      color: white;
      font-weight: 700;
      letter-spacing: 1px;
      cursor: pointer;
      transition: 0.25s;
    }

    .join-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(255, 122, 24, 0.4);
    }

    .join-btn.joined {
      background: #1e2235;
      color: #4a5068;
      cursor: not-allowed;
      border: 1px solid #2a2d3e;
    }

    /* NEW: MODAL & UTILITY STYLES */
    .edit-icon-btn {
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: white;
      border-radius: 6px;
      padding: 5px 10px;
      cursor: pointer;
      font-size: 12px;
      transition: 0.2s;
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 10;
    }

    .edit-icon-btn:hover {
      background: #ff7a18;
      border-color: #ff7a18;
    }

    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(11, 13, 23, 0.9);
      backdrop-filter: blur(5px);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: 0.3s;
    }

    .modal-overlay.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .modal-content {
      background: #161821;
      border: 1px solid rgba(255, 122, 24, 0.3);
      border-radius: 16px;
      width: 100%;
      max-width: 450px;
      padding: 30px;
      color: white;
    }

    .modal-content input,
    .modal-content select {
      width: 100%;
      padding: 12px;
      background: #0f1324;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: white;
      margin-bottom: 15px;
    }

    .save-btn {
      background: #ff7a18;
      border: none;
      padding: 12px;
      border-radius: 8px;
      color: white;
      width: 100%;
      font-weight: bold;
      cursor: pointer;
      margin-top: 10px;
    }
  </style>
</head>

<body>

  <div class="page">

    <%- include("../partials/navbar") %>

      <section class="dashboard">
        <div class="dashboard-container">

          <div class="dashboard-hero">
            <div style="display: flex; align-items: center; justify-content: center; gap: 15px; margin-bottom: 10px;">
              <h1 style="margin: 0;">
                <%= user.team %>
              </h1>
              <button onclick="document.getElementById('teamModal').classList.add('active')" class="edit-icon-btn"
                style="position: static; padding: 6px 12px; font-size: 14px;">✏️ Edit Team Name</button>
            </div>
            <p>Manage your team and dominate the court 🏀</p>
          </div>

          <div class="dashboard-actions">
            <div class="action-card">
              <h3>Live Games</h3>
              <p>Watch ongoing matches</p>
              <a href="/live" class="action-btn">View</a>
            </div>
            <div class="action-card">
              <h3>Team Statistics</h3>
              <p>View performance and analytics</p>
              <a href="/stats" class="action-btn secondary">View Stats</a>
            </div>
          </div>

          <%# Task 2: Team Stats — values pulled from teamStats object passed by /team-dashboard route %>
            <h3 class="section-title">Team Stats</h3>
            <div class="stats-container">
              <div class="stat-card">
                <h4>🏆 Wins</h4>
                <p>
                  <%= teamStats.wins %>
                </p>
              </div>
              <div class="stat-card">
                <h4>❌ Losses</h4>
                <p>
                  <%= teamStats.losses %>
                </p>
              </div>
              <div class="stat-card">
                <h4>🏀 Points</h4>
                <p>
                  <%= teamStats.points %>
                </p>
              </div>
              <div class="stat-card">
                <h4>📈 Rank</h4>
                <p>#--</p>
              </div>
            </div>

            <h3 class="section-title">Starting Lineup</h3>
            <div class="court">
              <% const PG=players.find(p=> p.position === "PG"); %>
                <% const SG=players.find(p=> p.position === "SG"); %>
                  <% const SF=players.find(p=> p.position === "SF"); %>
                    <% const PF=players.find(p=> p.position === "PF"); %>
                      <% const C=players.find(p=> p.position === "C"); %>

                        <% if(C){ %>
                          <div class="position c"><img src="<%= C.image %>"><span>
                              <%= C.name %>
                            </span><span class="pos">C</span></div>
                          <% } %>
                            <% if(PF){ %>
                              <div class="position pf"><img src="<%= PF.image %>"><span>
                                  <%= PF.name %>
                                </span><span class="pos">PF</span></div>
                              <% } %>
                                <% if(SF){ %>
                                  <div class="position sf"><img src="<%= SF.image %>"><span>
                                      <%= SF.name %>
                                    </span><span class="pos">SF</span></div>
                                  <% } %>
                                    <% if(PG){ %>
                                      <div class="position pg"><img src="<%= PG.image %>"><span>
                                          <%= PG.name %>
                                        </span><span class="pos">PG</span></div>
                                      <% } %>
                                        <% if(SG){ %>
                                          <div class="position sg"><img src="<%= SG.image %>"><span>
                                              <%= SG.name %>
                                            </span><span class="pos">SG</span></div>
                                          <% } %>
            </div>

            <div id="position-popup" class="position-popup">
              <p>Select Position</p>
              <button onclick="assignPosition('PG')">PG</button>
              <button onclick="assignPosition('SG')">SG</button>
              <button onclick="assignPosition('SF')">SF</button>
              <button onclick="assignPosition('PF')">PF</button>
              <button onclick="assignPosition('C')">C</button>
            </div>

            <div class="team-header">
              <h3 class="section-title">Team Members</h3>
              <a href="/add-player" class="add-player-btn">+ Add Player</a>
            </div>

            <div class="team-container">
              <% if(players.length===0){ %>
                <p class="empty-state">No players added yet</p>
                <% } %>

                  <% players.forEach(player=> { %>
                    <div class="player-card" data-id="<%= player.id %>" onclick="selectPlayer(this)"
                      style="position: relative;">

                      <button type="button" class="edit-icon-btn"
                        onclick="openPlayerEdit(event, '<%= player.id %>', '<%= player.name %>', '<%= player.role %>', '<%= player.position || '' %>')">✏️</button>

                      <form action="/remove-player/<%= player.id %>" method="POST">
                        <button type="submit" class="remove-player">×</button>
                      </form>

                      <img src="<%= player.image %>" class="player-img">
                      <h4 class="player-name">
                        <%= player.name %>
                      </h4>

                      <div class="player-info">
                        <span class="player-role">
                          <%= player.role %>
                        </span>
                        <% if(player.position){ %>
                          <span class="player-position">
                            <%= player.position %>
                          </span>
                          <% } %>
                      </div>

                      <%# Task 3: Mini box-score row — aggregated career totals from player_match_stats %>
                        <div
                          style="display:grid; grid-template-columns: repeat(6,1fr); gap:4px; margin-top:10px; padding-top:8px; border-top:1px solid rgba(255,255,255,0.07); text-align:center;">
                          <div style="font-size:10px; color:#a0a5b8;">PTS<br><span
                              style="font-size:14px; font-weight:700; color:#ff7a18;">
                              <%= player.points %>
                            </span></div>
                          <div style="font-size:10px; color:#a0a5b8;">AST<br><span
                              style="font-size:14px; font-weight:700; color:#ffffff;">
                              <%= player.assists %>
                            </span></div>
                          <div style="font-size:10px; color:#a0a5b8;">REB<br><span
                              style="font-size:14px; font-weight:700; color:#ffffff;">
                              <%= player.rebounds %>
                            </span></div>
                          <div style="font-size:10px; color:#a0a5b8;">STL<br><span
                              style="font-size:14px; font-weight:700; color:#ffffff;">
                              <%= player.steals %>
                            </span></div>
                          <div style="font-size:10px; color:#a0a5b8;">BLK<br><span
                              style="font-size:14px; font-weight:700; color:#ffffff;">
                              <%= player.blocks %>
                            </span></div>
                          <div style="font-size:10px; color:#a0a5b8;">MIN<br><span
                              style="font-size:14px; font-weight:700; color:#14b8a6;">
                              <%= player.matches_played > 0 ? Math.floor((player.seconds_played || 0) / player.matches_played / 60) : 0 %>
                            </span></div>
                        </div>
                        <button onclick="scoutPlayer('<%= player.id %>', '<%= player.name %>')" style="margin-top: 15px; width: 100%; background: rgba(168, 85, 247, 0.2); border: 1px solid #a855f7; color: #c084fc; padding: 8px; border-radius: 6px; cursor: pointer; transition: 0.2s; font-size: 12px; font-weight: bold;">🤖 Generate AI Scouting Report</button>
                    </div>
                    <% }) %>
            </div>

            <h3 class="section-title">Available Tournaments</h3>
            <% const registeredIds=registered.map(r=> r.tournament_id); %>
              <div class="tournament-container">
                <% tournaments.forEach(t=> { %>
                  <div class="tournament-card" onclick="window.location.href='/tournaments/<%= t.id %>'"
                    style="cursor:pointer;">
                    <div class="tournament-header">
                      <h4>
                        <%= t.name %>
                      </h4>
                      <span class="t-badge">OPEN</span>
                    </div>
                    <p class="t-location">📍 <%= t.location %>
                    </p>
                    <div class="t-footer">
                      <% if (registeredIds.includes(t.id)) { %>
                        <button class="join-btn joined" onclick="event.stopPropagation()">✓ Joined</button>
                        <% } else { %>
                          <form action="/tournaments/<%= t.id %>/register" method="POST"
                            onclick="event.stopPropagation()">
                            <button class="join-btn">Join Tournament</button>
                          </form>
                          <% } %>
                    </div>
                  </div>
                  <% }) %>
              </div>
        </div>
      </section>
  </div>

  <div class="modal-overlay" id="teamModal">
    <div class="modal-content">
      <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
        <h3 style="margin: 0;">Edit Team Details</h3>
        <button onclick="document.getElementById('teamModal').classList.remove('active')"
          style="background: none; border: none; color: #a0a5b8; cursor: pointer; font-size: 20px;">&times;</button>
      </div>
      <form action="/team/edit" method="POST">
        <label style="font-size: 12px; color: #a0a5b8; margin-bottom: 5px; display: block;">Team Name</label>
        <input type="text" name="team_name" value="<%= user.team %>" required>
        <p style="font-size: 11px; color: #ff5c5c; margin-bottom: 15px;">⚠️ Warning: Changing your team name will update
          it across all past and future tournament records.</p>
        <button type="submit" class="save-btn">Save Changes</button>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="playerModal">
    <div class="modal-content">
      <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
        <h3 style="margin: 0;">Edit Player</h3>
        <button onclick="document.getElementById('playerModal').classList.remove('active')"
          style="background: none; border: none; color: #a0a5b8; cursor: pointer; font-size: 20px;">&times;</button>
      </div>
      <form id="editPlayerForm" method="POST" enctype="multipart/form-data">
        <label style="font-size: 12px; color: #a0a5b8; margin-bottom: 5px; display: block;">Name</label>
        <input type="text" name="name" id="editPlayerName" required>

        <div style="display: flex; gap: 15px;">
          <div style="flex: 1;">
            <label style="font-size: 12px; color: #a0a5b8; margin-bottom: 5px; display: block;">Role</label>
            <select name="role" id="editPlayerRole" required>
              <option value="Player">Player</option>
              <option value="Captain">Captain</option>
              <option value="Coach">Coach</option>
            </select>
          </div>
          <div style="flex: 1;">
            <label style="font-size: 12px; color: #a0a5b8; margin-bottom: 5px; display: block;">Position</label>
            <select name="position" id="editPlayerPosition">
              <option value="">None</option>
              <option value="PG">PG (Point Guard)</option>
              <option value="SG">SG (Shooting Guard)</option>
              <option value="SF">SF (Small Forward)</option>
              <option value="PF">PF (Power Forward)</option>
              <option value="C">C (Center)</option>
            </select>
          </div>
        </div>

        <label style="font-size: 12px; color: #a0a5b8; margin-bottom: 5px; display: block;">Update Photo
          (Optional)</label>
        <input type="file" name="image" accept="image/*">

        <button type="submit" class="save-btn">Update Player</button>
      </form>
    </div>
  </div>

  <script>
    let selectedPlayer = null;

    function selectPlayer(el) {
      selectedPlayer = el.getAttribute("data-id");
      document.getElementById("position-popup").style.display = "block";
    }

    function assignPosition(pos) {
      fetch("/assign-position", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ playerId: selectedPlayer, position: pos })
      }).then(() => location.reload());
    }

    document.addEventListener("click", function (e) {
      const popup = document.getElementById("position-popup");
      if (!popup.contains(e.target) && !e.target.closest(".player-card")) {
        popup.style.display = "none";
      }
    });

    // Modals Logic updated to include position
    function openPlayerEdit(e, id, name, role, position) {
      e.stopPropagation(); // Prevents the court position popup from opening

      document.getElementById('editPlayerName').value = name;
      document.getElementById('editPlayerRole').value = role;
      document.getElementById('editPlayerPosition').value = position;

      // Set the form action dynamically to target this specific player
      document.getElementById('editPlayerForm').action = `/player/${id}/edit`;

      document.getElementById('playerModal').classList.add('active');
    }

    // AI Player Scouting Logic
    async function scoutPlayer(playerId, playerName) {
      const modal = document.getElementById('scoutModal');
      const loadingDiv = document.getElementById('scoutLoading');
      const dataDiv = document.getElementById('scoutData');
      
      modal.classList.add('active');
      loadingDiv.style.display = 'block';
      dataDiv.style.display = 'none';
      document.getElementById('scoutName').innerText = playerName;

      try {
        const response = await fetch(`/api/player-scout/${playerId}`);
        const data = await response.json();
        
        if (data.error) throw new Error(data.error);

        document.getElementById('scoutLevel').innerText = data.level;
        document.getElementById('scoutProjected').innerText = data.projected;
        document.getElementById('scoutStrength').innerText = data.strength;
        document.getElementById('scoutWeakness').innerText = data.weakness;
        document.getElementById('scoutSuggestion').innerText = data.suggestion;
        
        loadingDiv.style.display = 'none';
        dataDiv.style.display = 'block';
      } catch (err) {
        console.error(err);
        alert("Failed to load scouting report. Please ensure the AI Engine is running.");
        modal.classList.remove('active');
      }
    }
  </script>

  <div class="modal-overlay" id="scoutModal">
    <div class="modal-content">
      <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
        <h3 style="margin: 0;">🤖 AI Scouting Report</h3>
        <button onclick="document.getElementById('scoutModal').classList.remove('active')"
          style="background: none; border: none; color: #a0a5b8; cursor: pointer; font-size: 20px;">&times;</button>
      </div>
      <div id="scoutLoading" style="text-align: center; color: #a0a5b8; margin: 20px 0;">
        <p>Analyzing player data...</p>
      </div>
      <div id="scoutData" style="display: none;">
        <h4 id="scoutName" style="color: #fff; margin-bottom: 5px;">--</h4>
        <div style="display: flex; gap: 10px; margin-bottom: 15px;">
          <span style="background: rgba(168, 85, 247, 0.2); color: #c084fc; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;" id="scoutLevel">-- TIER</span>
          <span style="background: rgba(34, 197, 94, 0.2); color: #22c55e; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;">Projected PTS: <span id="scoutProjected">--</span></span>
        </div>
        <div style="margin-bottom: 10px;">
          <span style="font-size: 11px; color: #a0a5b8; text-transform: uppercase;">Top Strength</span>
          <p id="scoutStrength" style="color: #fff; margin: 2px 0 0 0; font-size: 14px;">--</p>
        </div>
        <div style="margin-bottom: 10px;">
          <span style="font-size: 11px; color: #a0a5b8; text-transform: uppercase;">Area to Improve</span>
          <p id="scoutWeakness" style="color: #fff; margin: 2px 0 0 0; font-size: 14px;">--</p>
        </div>
        <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1);">
          <span style="font-size: 11px; color: #a0a5b8; text-transform: uppercase;">AI Suggestion</span>
          <p id="scoutSuggestion" style="color: #ff7a18; margin: 5px 0 0 0; font-size: 14px; font-style: italic;">--</p>
        </div>
      </div>
    </div>
  </div>

</body>

</html>