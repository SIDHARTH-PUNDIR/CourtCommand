<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= tournament.name %>
  </title>
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
  <style>
    /* =========================
   GLOBAL
========================= */
    body { background: #0b0d17; color: #e8eaf0; font-family: 'Barlow', sans-serif; line-height: 1.6; }

    /* =========================
   HERO SECTION
========================= */
    .t-hero { padding: 80px 60px; background: radial-gradient(circle at top left, #1a1c2c, #0b0d17); border-bottom: 1px solid rgba(255, 122, 24, 0.1); display: flex; justify-content: space-between; align-items: center; }
    .t-hero h1 { font-family: 'Anton', sans-serif; font-size: 48px; letter-spacing: 2px; color: white; margin: 0; }
    .t-hero-meta { margin-top: 10px; display: flex; gap: 24px; }
    .t-hero-meta span { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: #4a5068; }
    .t-hero-meta span strong { color: #ff7a18; }

    /* =========================
   BUTTONS
========================= */
    .register-btn { background: #ff7a18; color: white; border: none; padding: 14px 30px; border-radius: 10px; font-family: 'Barlow Condensed', sans-serif; font-size: 15px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: 0.25s; text-decoration: none; }
    .register-btn:hover { background: #ff8f32; transform: translateY(-2px); box-shadow: 0 10px 25px rgba(255, 122, 24, 0.4); }
    .register-btn.disabled { background: #1e2030; color: #4a5068; cursor: not-allowed; border: 1px solid #2a2d3e; }

    /* =========================
   BODY LAYOUT
========================= */
    .t-body { max-width: 1300px; margin: 0 auto; padding: 40px 20px; }
    .top-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: start; margin-bottom: 50px; }

    /* =========================
   SECTION TITLE
========================= */
    .section-title { font-family: 'Barlow Condensed', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: #ff7a18; margin-bottom: 25px; display: flex; align-items: center; gap: 10px; }
    .section-title::after { content: ""; flex: 1; height: 1px; background: rgba(255, 122, 24, 0.2); }

    /* =========================
   FIXTURE CARDS
========================= */
    .round-block { margin-bottom: 40px; }
    .round-title { font-size: 14px; letter-spacing: 2px; color: #fff; background: rgba(255, 122, 24, 0.1); display: inline-block; padding: 6px 16px; border-radius: 6px; margin-bottom: 15px; font-weight: 700; }
    .fixture-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; margin-bottom: 15px; overflow: hidden; display: flex; flex-direction: column; }
    .fixture-main { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 20px; }
    .team-name-card { font-size: 18px; font-weight: 700; letter-spacing: 1px; }
    .team-left { text-align: right; }
    .team-right { text-align: left; }
    .match-center { display: flex; flex-direction: column; align-items: center; padding: 0 30px; position: relative; }
    .score-display { font-size: 24px; font-weight: 800; font-family: 'Anton', sans-serif; letter-spacing: 2px; }
    .score-display.muted { color: #4a5068; font-size: 18px; }
    .status-badge { font-size: 10px; font-weight: 700; letter-spacing: 2px; padding: 3px 8px; border-radius: 4px; margin-top: 5px; }
    .status-badge.live { background: #ff3b3b; color: white; animation: pulse 2s infinite; }
    .status-badge.final { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .status-badge.upcoming { background: rgba(255, 255, 255, 0.1); color: #a0a5b8; }
    .match-date { font-size: 11px; color: #a0a5b8; margin-top: 5px; text-transform: uppercase; letter-spacing: 1px; }

    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(255, 59, 59, 0.4); } 70% { box-shadow: 0 0 0 6px rgba(255, 59, 59, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 59, 59, 0); } }

    /* =========================
   TABLE & LISTS
========================= */
    .card-panel { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 16px; padding: 24px; }
    .leaderboard-table { width: 100%; border-collapse: collapse; }
    .leaderboard-table th { font-size: 11px; color: #4a5068; padding: 10px; text-align: left; }
    .leaderboard-table td { padding: 12px 10px; border-bottom: 1px solid rgba(255, 255, 255, 0.03); }
    .team-row { display: flex; align-items: center; padding: 10px; border-bottom: 1px solid rgba(255, 255, 255, 0.04); }
    .team-rank { width: 30px; color: #666; }
    .team-name { flex: 1; font-weight: 600; }
    .slots-left { text-align: center; margin-top: 16px; font-size: 12px; letter-spacing: 2px; color: #4a5068; }
    .slots-left strong { color: #ff7a18; }
    .no-fixtures { text-align: center; padding: 40px; color: #4a5068; font-size: 14px; letter-spacing: 2px; background: rgba(255, 255, 255, 0.02); border-radius: 12px; }
  </style>
</head>

<body>

  <%- include("../partials/navbar") %>

    <div class="t-hero">
      <div>
        <h1>
          <%= tournament.name.toUpperCase() %>
        </h1>
        <% if (tournament.champion) { %>
          <div style="margin-top: 15px; display: flex; gap: 10px; flex-wrap: wrap;">
            <div style="background: linear-gradient(90deg, #ffd700, #ff8f00); color: #000; padding: 8px 16px; border-radius: 6px; font-weight: 800; font-size: 14px;">
              🥇 1ST: <%= tournament.champion.toUpperCase() %>
            </div>
            <% if (tournament.runner_up) { %>
              <div style="background: linear-gradient(90deg, #e0e0e0, #9e9e9e); color: #000; padding: 8px 16px; border-radius: 6px; font-weight: 800; font-size: 14px;">
                🥈 2ND: <%= tournament.runner_up.toUpperCase() %>
              </div>
              <% } %>
                <% if (tournament.second_runner_up) { %>
                  <div style="background: linear-gradient(90deg, #cd7f32, #8d5524); color: #fff; padding: 8px 16px; border-radius: 6px; font-weight: 800; font-size: 14px;">
                    🥉 3RD: <%= tournament.second_runner_up.toUpperCase() %>
                  </div>
                  <% } %>
          </div>
          <% } %>
            <div class="t-hero-meta">
              <span>📍 <strong><%= tournament.location %></strong></span>
              <span>📅 <strong>
                  <%= new Date(tournament.start_date).toLocaleDateString('en-IN', { day: 'numeric' , month: 'short' , year: 'numeric' }) %>
                    —
                    <%= new Date(tournament.end_date).toLocaleDateString('en-IN', { day: 'numeric' , month: 'short' , year: 'numeric' }) %>
                </strong></span>
              <span>👥 <strong><%= teams.length %> / <%= tournament.max_teams %></strong> teams</span>
            </div>
      </div>

      <% if (!user) { %>
        <a href="/login" class="register-btn">Sign In to Register</a>
        <% } else if (isRegistered) { %>
          <span class="register-btn disabled">✓ Registered</span>
          <% } else if (teams.length>= tournament.max_teams) { %>
            <span class="register-btn disabled">Tournament Full</span>
            <% } else { %>
              <form action="/tournaments/<%= tournament.id %>/register" method="POST">
                <button type="submit" class="register-btn">Register Team</button>
              </form>
              <% } %>
    </div>

    <div class="t-body">
      <div class="top-grid">

        <div>
          <div class="section-title">Standings</div>

          <% 
              // DYNAMIC GROUP DETECTOR 
              const groupMap={}; 
              let hasGroups=false; 
              matches.forEach(m=> {
                if (m.round.includes("STAGE")) {
                  hasGroups = true;
                  if (!groupMap[m.round]) groupMap[m.round] = new Set();
                  groupMap[m.round].add(m.teama);
                  groupMap[m.round].add(m.teamb);
                }
              });
            %>

            <% if (leaderboard.length===0) { %>
              <div class="card-panel">
                <div class="no-fixtures">STANDINGS UPDATE AFTER FIRST MATCH</div>
              </div>
              <% } else if (hasGroups) { %>

                <% Object.keys(groupMap).sort().forEach(groupName=> { %>
                  <div class="card-panel" style="margin-bottom: 20px;">
                    <div style="color: #ff7a18; font-weight: 700; margin-bottom: 10px; font-size: 12px; letter-spacing: 1px;">
                      <%= groupName %>
                    </div>
                    <table class="leaderboard-table">
                      <thead>
                        <tr>
                          <th>#</th>
                          <th>Team</th>
                          <th>MP</th>
                          <th>W</th>
                          <th>L</th>
                          <th>T</th>
                          <th style="color:#ff7a18">Pts</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% 
                            const groupTeams=Array.from(groupMap[groupName]); 
                            const filteredBoard=leaderboard.filter(t=> groupTeams.includes(t.team_name));
                            filteredBoard.forEach((t, i) => {
                          %>
                          <tr>
                            <td><span class="rank-pill"><%= i + 1 %></span></td>
                            <td style="font-weight: 600;"><%= t.team_name %></td>
                            <td><%= t.matches_played %></td>
                            <td><%= t.wins %></td>
                            <td><%= t.losses %></td>
                            <td><%= t.ties || 0 %></td>
                            <td style="color:#ff7a18; font-weight: 700;"><%= t.points %></td>
                          </tr>
                          <% }) %>
                      </tbody>
                    </table>
                  </div>
                  <% }) %>

                    <% } else { %>

                      <div class="card-panel">
                        <table class="leaderboard-table">
                          <thead>
                            <tr>
                              <th>#</th>
                              <th>Team</th>
                              <th>MP</th>
                              <th>W</th>
                              <th>L</th>
                              <th>T</th>
                              <th style="color:#ff7a18">Pts</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% leaderboard.forEach((t, i)=> { %>
                              <tr>
                                <td><span class="rank-pill"><%= i + 1 %></span></td>
                                <td style="font-weight: 600;"><%= t.team_name %></td>
                                <td><%= t.matches_played %></td>
                                <td><%= t.wins %></td>
                                <td><%= t.losses %></td>
                                <td><%= t.ties || 0 %></td>
                                <td style="color:#ff7a18; font-weight: 700;"><%= t.points %></td>
                              </tr>
                              <% }) %>
                          </tbody>
                        </table>
                      </div>
                      <% } %>
        </div>

        <div>
          <div class="section-title">Participating Teams</div>
          <div class="card-panel">
            <% teams.forEach((t, i)=> { %>
              <div class="team-row">
                <span class="team-rank">#<%= i + 1 %></span>
                <span class="team-name"><%= t.team_name %></span>
              </div>
              <% }) %>
                <div class="slots-left">
                  <strong><%= tournament.max_teams - teams.length %></strong> slots remaining
                </div>
          </div>
        </div>
      </div>

      <div class="fixtures-full">
        <div class="section-title">Match Fixtures</div>

        <% if (matches.length===0) { %>
          <div class="no-fixtures">FIXTURES HAVE NOT BEEN GENERATED YET</div>
          <% } else { %>
            <% const grouped={}; matches.forEach(m=> {
                if (!grouped[m.round]) grouped[m.round] = [];
                grouped[m.round].push(m);
              });
            %>

              <% Object.keys(grouped).forEach(round=> { %>
                <div class="round-block">
                  <div class="round-title"><%= round %></div>

                  <div class="fixtures-grid">
                    <% grouped[round].forEach(match=> { %>

                      <div class="fixture-card">
                        <div class="fixture-main">
                          <div class="team-name-card team-left"><%= match.teama %></div>

                          <div class="match-center">
                            <% if (match.status==='FINAL' || match.status==='LIVE' ) { %>
                              <div class="score-display"><%= match.scorea %> - <%= match.scoreb %></div>
                              <% } else { %>
                                <div class="score-display muted">VS</div>
                                <% } %>
                                  <div class="status-badge <%= match.status.toLowerCase() %>"><%= match.status %></div>
                                  <div class="match-date">
                                    <%= match.match_date ? new Date(match.match_date).toLocaleDateString('en-IN', { day: 'numeric' , month: 'short' }) : 'Date TBD' %>
                                  </div>
                          </div>

                          <div class="team-name-card team-right"><%= match.teamb %></div>
                        </div>
                      </div>

                      <% }) %>
                  </div>
                </div>
                <% }) %>
                  <% } %>
      </div>
    </div>

</body>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('error') === 'roster') {
    alert('Your team must have at least 5 players to register for a tournament.');
    window.history.replaceState(null, '', window.location.pathname);
  }
</script>

</html>