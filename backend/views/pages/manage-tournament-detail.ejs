<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Manage <%= tournament.name %></title>
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
  <style>
    body { background: #0b0d17; color: #e8eaf0; font-family: 'Barlow', sans-serif; line-height: 1.6; }
    .t-hero { padding: 40px 60px; background: #161821; border-bottom: 1px solid rgba(255,122,24,0.3); }
    .t-hero h1 { font-family: 'Anton', sans-serif; font-size: 36px; color: white; margin: 0; }
    
    .action-btn { background: linear-gradient(90deg, #ff7a18, #ff8f32); border: none; padding: 10px 18px; border-radius: 8px; color: white; cursor: pointer; font-weight: 600; font-size: 14px; text-decoration: none; display: inline-block; }
    .danger-btn { background: rgba(255, 59, 59, 0.1); border: 1px solid rgba(255, 59, 59, 0.4); padding: 10px 15px; border-radius: 8px; color: #ff5c5c; cursor: pointer; font-weight: 600; }
    
    .management-wrapper { max-width: 1300px; margin: 40px auto; padding: 0 20px; }
    .section-title { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #ff7a18; margin-bottom: 25px; border-bottom: 1px solid rgba(255,122,24,0.2); padding-bottom: 10px;}
    
    .admin-controls-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 50px; }
    .admin-box { background: rgba(255,255,255,0.03); padding: 20px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.05); }
    .admin-box-title { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #a0a5b8; font-weight: 600; margin-bottom: 15px; }
    
    input, select { padding: 10px 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: #0f1324; color: white; width: 100%; box-sizing: border-box; font-family: 'Barlow', sans-serif; }
    .admin-row { display: flex; gap: 10px; }
    
    .fixture-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; }
    .fixture-admin { display: flex; gap: 15px; align-items: center; }
    .quick-update-form { display: flex; gap: 8px; align-items: center; }
    .quick-update-form input { width: 50px; text-align: center; }

    /* Modal Styles */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(11, 13, 23, 0.9); backdrop-filter: blur(5px); display: flex; justify-content: center; align-items: center; z-index: 1000; opacity: 0; visibility: hidden; pointer-events: none; transition: 0.3s; }
    .modal-overlay.active { opacity: 1; visibility: visible; pointer-events: auto; }
    .modal-content { background: #161821; border: 1px solid rgba(255,122,24,0.3); border-radius: 16px; width: 100%; max-width: 500px; padding: 30px; }
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; font-size: 12px; color: #a0a5b8; text-transform: uppercase; margin-bottom: 5px; }
  </style>
</head>
<body>
<%- include("../partials/navbar") %>

<div class="t-hero">
  <a href="/admin" style="color: #a0a5b8; text-decoration: none; font-size: 14px;">&larr; Back to Command Center</a>
  <h1 style="margin-top: 10px;">MANAGE: <%= tournament.name.toUpperCase() %></h1>
  <p style="color: #ff7a18; font-weight: 600;"><%= tournament.status %> | <%= teams.length %> / <%= tournament.max_teams %> Teams Registered</p>
</div>

<div class="management-wrapper">

  <div class="section-title">Core Setup & Settings</div>
  <div class="admin-controls-grid">
    
    <div class="admin-box" style="border: 1px solid rgba(255, 122, 24, 0.4);">
      <div class="admin-box-title" style="color: #ff7a18;">Tournament Details</div>
      <button type="button" class="action-btn" id="openSettingsBtn" style="width: 100%; background: #2a2d3e; border: 1px solid #ff7a18;">✏️ Edit Information</button>
    </div>

    <div class="admin-box">
      <div class="admin-box-title">Tournament Engine</div>
      <button type="button" class="action-btn" id="openWizardBtn" style="width: 100%;">⚙️ Fixture Generator</button>
    </div>

    <div class="admin-box">
      <div class="admin-box-title">Season Lifecycle</div>
      <form action="/tournaments/<%= tournament.id %>/reset" method="POST" style="margin-bottom: 10px;">
        <button class="action-btn" style="width: 100%; background: #4a5068;" onclick="return confirm('Reset all fixtures to 0?')">🔄 Hard Reset</button>
      </form>
      <% if (tournament.status !== 'COMPLETED') { %>
        <form action="/tournaments/<%= tournament.id %>/finalize" method="POST">
          <button class="action-btn" style="width: 100%; background: #22c55e;" onclick="return confirm('Crown Champions?')">🏆 Finalize Tournament</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="section-title">Registered Teams (<%= teams.length %> / <%= tournament.max_teams %>)</div>
  <div class="admin-controls-grid" style="margin-bottom: 40px;">
    <div class="admin-box" style="grid-column: 1 / -1;">
      <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 15px;">
        <% teams.forEach(t => { %>
          <div style="background: rgba(255,255,255,0.05); padding: 8px 15px; border-radius: 6px; display: flex; align-items: center; gap: 10px;">
            <strong style="color: white;"><%= t.team_name %></strong>
            <form action="/tournaments/<%= tournament.id %>/remove-team/<%= t.id %>" method="POST" style="margin: 0;">
              <button style="background: none; border: none; color: #ff5c5c; cursor: pointer; font-size: 16px;">&times;</button>
            </form>
          </div>
        <% }) %>
      </div>
      <form action="/tournaments/<%= tournament.id %>/add-team" method="POST" class="admin-row" style="max-width: 400px;">
        <select name="team_id" required>
          <option value="" disabled selected>-- Select a Team --</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.team %></option>
          <% }) %>
        </select>
        <button class="action-btn">Add Team</button>
      </form>
    </div>
  </div>

  <div class="section-title">Match Administration</div>
  <% if (matches.length === 0) { %>
    <div style="text-align: center; color: #a0a5b8; padding: 40px;">No fixtures generated yet. Use the engine above.</div>
  <% } else { %>
    <% matches.forEach(match => { %>
      <div class="fixture-card">
        <div>
          <span style="color: #ff7a18; font-size: 12px; font-weight: 700; display: block;"><%= match.round %></span>
          <strong style="font-size: 18px;"><%= match.teama %></strong> vs <strong style="font-size: 18px;"><%= match.teamb %></strong>
          <% if(match.status === 'FINAL') { %> <span style="margin-left: 10px; background: #22c55e; padding: 2px 6px; border-radius: 4px; font-size: 10px;">FINAL</span> <% } %>
        </div>

        <div class="fixture-admin" style="flex-wrap: wrap;">
          <form action="/matches/<%= match.id %>/edit-teams" method="POST" class="quick-update-form">
            <input type="text" name="teamA" value="<%= match.teama %>" required> <span style="font-size: 10px;">vs</span>
            <input type="text" name="teamB" value="<%= match.teamb %>" required>
            <button class="action-btn" style="padding: 8px; background: #4a5068;">Set</button>
          </form>

          <form action="/matches/<%= match.id %>/edit-date" method="POST" class="quick-update-form" style="border-left: 1px solid rgba(255,255,255,0.1); padding-left: 15px; margin-left: 5px;">
            <input type="date" name="match_date" value="<%= match.match_date ? new Date(match.match_date).toISOString().split('T')[0] : '' %>" style="width: 120px; font-size: 12px; padding: 0 5px;" title="Set Match Date">
            <button class="action-btn" style="padding: 8px; background: #4a5068;">📅</button>
          </form>

          <form action="/matches/<%= match.id %>/result" method="POST" class="quick-update-form" style="border-left: 1px solid rgba(255,255,255,0.1); padding-left: 15px; margin-left: 5px;">
            <input type="number" name="scoreA" placeholder="A" value="<%= match.scorea %>" required>
            <input type="number" name="scoreB" placeholder="B" value="<%= match.scoreb %>" required>
            <button class="action-btn" style="padding: 8px;">Save</button>
          </form>
          <% if (match.status === 'UPCOMING') { %>
            <form action="/matches/<%= match.id %>/set-live" method="POST" style="margin-left: 10px;">
              <button class="action-btn" style="background: #ff3b3b; padding: 8px 12px; border: 1px solid #cc0000;" title="Mark as Live">🔥 Set Live</button>
            </form>
          <% } %>

          <%# Feature 6: Revert button for LIVE or FINAL matches %>
          <% if (match.status === 'LIVE' || match.status === 'FINAL') { %>
            <form action="/matches/<%= match.id %>/revert" method="POST" style="margin-left: 10px;"
                  onsubmit="return confirm('Revert this match to UPCOMING? Scores will reset to 0 and standings will be recalculated.')">
              <button class="action-btn"
                style="background: rgba(234,179,8,0.12); border: 1px solid #eab308; color: #eab308; padding: 8px 12px;"
                title="Revert to UPCOMING">↺ Revert</button>
            </form>
          <% } %>

          <a href="/score-match/<%= match.id %>" class="action-btn" style="background: #22c55e; padding: 8px 12px; margin-left: 10px; border: 1px solid #16a34a; text-decoration: none;">🔴 Live Scorer</a>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<div class="modal-overlay" id="settingsModal">
  <div class="modal-content">
    <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
      <h2 style="margin: 0; color: white;">Edit Tournament</h2>
      <button class="danger-btn" id="closeSettingsBtn" style="padding: 5px 10px; border: none; background: none;">&times;</button>
    </div>
    <form action="/tournaments/<%= tournament.id %>/edit" method="POST">
      <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= tournament.name %>" required></div>
      <div class="form-group"><label>Location</label><input type="text" name="location" value="<%= tournament.location %>" required></div>
      <div class="admin-row">
        <div class="form-group" style="flex: 1;"><label>Start Date</label><input type="date" name="start_date" value="<%= tournament.start_date ? new Date(tournament.start_date).toISOString().split('T')[0] : '' %>" required></div>
        <div class="form-group" style="flex: 1;"><label>End Date</label><input type="date" name="end_date" value="<%= tournament.end_date ? new Date(tournament.end_date).toISOString().split('T')[0] : '' %>" required></div>
      </div>
      <div class="form-group"><label>Max Teams</label><input type="number" name="max_teams" value="<%= tournament.max_teams %>" required></div>
      <div class="form-group"><label>Cover Image URL/Path</label><input type="text" name="image" value="<%= tournament.image %>"></div>
      <button type="submit" class="action-btn" style="width: 100%; margin-top: 10px;">💾 Save Changes</button>
    </form>
  </div>
</div>

<div class="modal-overlay" id="fixtureModal">
  <div class="modal-content">
    <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
      <h2 style="margin: 0; color: white;">Fixture Engine</h2>
      <button class="danger-btn" id="closeWizardBtn" style="padding: 5px 10px; border: none; background: none;">&times;</button>
    </div>
    <form action="/admin/generate-fixtures/<%= tournament.id %>" method="POST">
      <div class="form-group"><label>Format</label>
        <select name="type" id="formatSelect">
          <option value="knockout">Standard Knockout</option>
          <option value="round">Round Robin</option>
          <option value="hybrid">Hybrid (Groups + Knockout)</option>
          <option value="custom">Custom Canvas</option>
        </select>
      </div>
      <div id="hybridSettings" style="display: none; background: rgba(255,122,24,0.05); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
        <div class="form-group"><label>Groups</label><select name="group_count"><option value="2">2</option><option value="4">4</option></select></div>
        <div class="form-group"><label>Advancing</label><select name="advancing_count"><option value="1">Top 1</option><option value="2" selected>Top 2</option></select></div>
      </div>
      <button type="submit" class="action-btn" style="width: 100%;">🚀 Generate</button>
    </form>
  </div>
</div>

<script>
  // Simple Modal Logic
  const bindModal = (openId, closeId, modalId) => {
    const openBtn = document.getElementById(openId), closeBtn = document.getElementById(closeId), modal = document.getElementById(modalId);
    if(openBtn && closeBtn && modal) {
      openBtn.onclick = () => modal.classList.add('active');
      closeBtn.onclick = (e) => { e.preventDefault(); modal.classList.remove('active'); };
      modal.onclick = (e) => { if (e.target === modal) modal.classList.remove('active'); };
    }
  };

  bindModal('openSettingsBtn', 'closeSettingsBtn', 'settingsModal');
  bindModal('openWizardBtn', 'closeWizardBtn', 'fixtureModal');

  // Hybrid Toggle
  const formatSelect = document.getElementById("formatSelect");
  const hybridSettings = document.getElementById("hybridSettings");
  if(formatSelect) {
    formatSelect.addEventListener("change", (e) => {
      hybridSettings.style.display = e.target.value === "hybrid" ? "block" : "none";
    });
  }
</script>
</body>
</html>