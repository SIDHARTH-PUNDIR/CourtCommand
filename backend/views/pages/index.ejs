<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Court Command</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="stylesheet" href="/css/styles.css" />

  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

</head>

<body class="HOME">

  <!-- SCOREBOARD -->
  <%- include("../partials/scoreboard") %>

    <!-- NAVBAR -->
    <%- include("../partials/navbar") %>


      <!-- HERO-->

      <section class="hero">
        <div class="scroll-indicator">↓</div>

        <div class="content">

          <h1>STEP ONTO THE COURT<br />COMPETE FOR THE TITLE</h1>

          <p>
            Join tournaments, follow live matches,<br />
            and track your team's journey to the championship.
          </p>

          <div class="buttons">
            <button onclick="location.href='/register'" class="register">
              Register
            </button>
            <button onclick="location.href='/live'" class="live">
              Live Score
            </button>
          </div>

          <img src="/assets/victor.png" alt="Graphic" class="vector-graphic" />

        </div>

        <div class="ball">
          <img src="/assets/ball.png" alt="Basketball" />
        </div>

      </section>



      <!-- Tournament -->

      <section class="tournaments-section">

        <div class="tournaments-container">

          <h2 class="tournaments-title">COMPETE IN TOURNAMENTS</h2>

          <div class="tournaments-grid">

            <a href="/tournaments/1" class="tournament-card">
              <img src="/assets/tournaments/spring.png">
              <div class="tournament-info">
                <h3>Spring Cup</h3>
                <p>March 2026</p>
              </div>
            </a>

            <a href="/tournaments/2" class="tournament-card">
              <img src="/assets/tournaments/summer.png">
              <div class="tournament-info">
                <h3>Summer League</h3>
                <p>June 2026</p>
              </div>
            </a>

            <a href="/tournaments/3" class="tournament-card">
              <img src="/assets/tournaments/city.png">
              <div class="tournament-info">
                <h3>City Championship</h3>
                <p>August 2026</p>
              </div>
            </a>

            <a href="/tournaments/4" class="tournament-card">
              <img src="/assets/tournaments/finals.png">
              <div class="tournament-info">
                <h3>Grand Finals</h3>
                <p>December 2026</p>
              </div>
            </a>

          </div>

        </div>

      </section>



      <!-- winners -->

      <section class="standings-section">

        <h2 class="standings-heading" id="yearTitle">
          SEASON CHAMPIONS 2025
        </h2>

        <!-- YEAR SELECT -->
        <div class="year-selector">
          <button onclick="changeYear(2025)">2025</button>
          <button onclick="changeYear(2024)">2024</button>
          <button onclick="changeYear(2023)">2023</button>
        </div>

        <div class="podium" id="podium">

          <!-- content will be filled by JS -->

        </div>

        <div class="leader-stats" id="leaders"></div>

      </section>



      <!-- cards -->

      <section class="bootstrap-section scroll-reveal">

        <div class="container px-4 py-5" id="custom-cards">

          <h2 class="pb-2 border-bottom" style="color: orange;">Core Features</h2>

          <div class="row row-cols-1 row-cols-lg-3 align-items-stretch g-4 py-5">

            <div class="col">
              <div class="card card-cover h-100 overflow-hidden text-bg-dark rounded-4 shadow-lg"
                style="background-image: url(/assets/live.webp)">
                <div class="d-flex flex-column h-100 p-5 pb-3 text-white text-shadow-1">

                  <h3 class="pt-5 mt-5 mb-3 display-6 fw-bold" style="color:white;">
                    Live Match Scoring
                  </h3>

                  <p class="fs-5" style="color: aliceblue;">
                    Real-time points, fouls, and game clock updates.
                  </p>

                </div>
              </div>
            </div>


            <div class="col">

              <div class="card card-cover h-100 overflow-hidden text-bg-dark rounded-4 shadow-lg"
                style="background-image: url(/assets/cards/michael-jordan-3840x2160-17312.jpg)">

                <div class="d-flex flex-column h-100 p-5 pb-3 text-white text-shadow-1">

                  <h3 class="pt-5 mt-5 mb-3 display-6 fw-bold" style="color:white;">
                    Tournament Management
                  </h3>

                  <p class="fs-5" style="color: aliceblue;">
                    Create tournaments, organize brackets, schedule matches,
                    and manage teams seamlessly.
                  </p>

                </div>
              </div>
            </div>


            <div class="col">

              <div class="card card-cover h-100 overflow-hidden text-bg-dark rounded-4 shadow-lg"
                style="background-image: url(/assets/cards/details-ball-sport_23-2151869771.avif)">

                <div class="d-flex flex-column h-100 p-5 pb-3 text-white bg-dark bg-opacity-50 rounded-3">

                  <h3 class="pt-5 mt-5 mb-3 display-6 fw-bold text-white">
                    Player & Team Analytics
                  </h3>

                  <p class="fs-5" style="color: white">
                    View detailed statistics, performance insights,
                    and leaderboard rankings for every team and player.
                  </p>

                </div>
              </div>
            </div>

          </div>
        </div>

      </section>



      <!-- footer -->

      <%- include("../partials/footer") %>



        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        <script>

          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add("show");
              }
            });
          });

          document.querySelectorAll(".scroll-reveal").forEach(el => {
            observer.observe(el);
          });

          const scoreboard = document.querySelector('.scoreboard-bar');
          const navbar = document.querySelector('.main-navbar');

          window.addEventListener('scroll', () => {
            if (window.scrollY > 90) {
              navbar.classList.add('scrolled');  // ← adds .scrolled to navbar
            } else {
              navbar.classList.remove('scrolled');  // ← removes .scrolled from navbar
            }
          });






          const winnersData = {

            2025: {
              champion: { name: "APEX GORILLAS", logo: "/assets/club/apex.png" },
              second: { name: "SHADOW HOOPS", logo: "/assets/club/shadow.png" },
              third: { name: "VIKING REAVERS", logo: "/assets/club/viking.png" },
              scorer: { name: "Alex Carter", stat: "38 PPG" },
              team: { name: "Mist Club", stat: "112 Avg Points" }
            },

            2024: {
              champion: { name: "SKY EAGLES", logo: "/assets/club/sky.png" },
              second: { name: "APEX GORILLAS", logo: "/assets/club/apex.png" },
              third: { name: "VIKING REAVERS", logo: "/assets/club/viking.png" },
              scorer: { name: "John Blaze", stat: "35 PPG" },
              team: { name: "Apex Gorillas", stat: "105 Avg Points" }
            },

            2023: {
              champion: { name: "VIKING REAVERS", logo: "/assets/club/viking.png" },
              second: { name: "SHADOW HOOPS", logo: "/assets/club/shadow.png" },
              third: { name: "RHINO RAMPAGE", logo: "/assets/club/rhino.png" },
              scorer: { name: "Ravi Singh", stat: "33 PPG" },
              team: { name: "Shadow Hoops", stat: "101 Avg Points" }
            }

          };

          function changeYear(year) {

            const data = winnersData[year];

            document.getElementById("yearTitle").innerText =
              `SEASON CHAMPIONS ${year}`;

            document.getElementById("podium").innerHTML = `
    
    <div class="podium-card second">
      <img src="${data.second.logo}" class="team-logo">
      <h3>${data.second.name}</h3>
      <p class="position">Runner Up</p>
      <div class="medal silver">2</div>
    </div>

    <div class="podium-card first">
      <img src="${data.champion.logo}" class="team-logo">
      <h3>${data.champion.name}</h3>
      <p class="position">Champion</p>
      <div class="medal gold">1</div>
    </div>

    <div class="podium-card third">
      <img src="${data.third.logo}" class="team-logo">
      <h3>${data.third.name}</h3>
      <p class="position">3rd Place</p>
      <div class="medal bronze">3</div>
    </div>
  `;

            document.getElementById("leaders").innerHTML = `
    <div class="leader-card">
      <h4>🔥 Best Scorer</h4>
      <p>${data.scorer.name}</p>
      <span>${data.scorer.stat}</span>
    </div>

    <div class="leader-card">
      <h4>⚡ Top Scoring Team</h4>
      <p>${data.team.name}</p>
      <span>${data.team.stat}</span>
    </div>
  `;
          }

          // 🔥 Load default year
          changeYear(2025);


        </script>

</body>

</html>